rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ===============================
       PUBLIC WEBSITE CONTENT
    =============================== */

    // School configuration
    match /school/{docId} {
      allow read: if true;
      allow write: if isApprovedAdmin();
    }

    // Notices
    match /notices/{docId} {
      allow read: if true;
      allow write: if isApprovedAdmin();
    }

    // Gallery
    match /gallery/{docId} {
      allow read: if true;
      allow write: if isApprovedAdmin();
    }

    // Static content
    match /content/{docId} {
      allow read: if true;
      allow write: if isApprovedAdmin();
    }

    // Admissions
    match /admissions/{docId} {
      allow create: if true;
      allow read, update, delete: if isApprovedAdmin();
    }

    /* ===============================
       ADMINS
    =============================== */

    match /admins/{userId} {

      // user can read their own admin document
      allow read: if request.auth != null &&
                  request.auth.uid == userId;

      // allow admin registration
      allow create: if request.auth != null &&
                    request.auth.uid == userId;

      // only approved admins can update
      allow update: if isApprovedAdmin();

      allow delete: if false;
    }

    /* ===============================
       SECURITY & LOGS
    =============================== */

    match /admin_login_activities/{id} {
      allow create: if true;
      allow read: if isApprovedAdmin();
    }

    match /security_events/{id} {
      allow create: if true;
      allow read: if isApprovedAdmin();
    }

    match /rate_limits/{id} {
      allow read, write: if true;
    }

    /* ===============================
       HELPER FUNCTION
    =============================== */

    function isApprovedAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == "approved";
    }
  }
}
